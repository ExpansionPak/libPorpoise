#############
# All
#############
all: dobuild
release: 
	@make -f pcmakefile dobuild
debug: 
	@make -f pcmakefile DEBUG=1 dobuild
dobuild: $(TARGET_BINS)

#############
# .c => .obj
#############
$(OBJ_ROOT)/%.obj: $(SOURCE_ROOT)/%.c
	@if [ ! -d $(@D) ] ; then \
		echo ">>> Creating $(@D)" ; \
		mkdir -p $(@D) ; \
	fi	
	@echo 
	@echo ">> $+ --> $@"
	$(CC) $(CCFLAGS) $(INCLUDES) $(COMPILE) $< \
		/Fo$(subst $(FULLBINOBJ_ROOT)/,$(BINOBJ_ROOT)/,$@)

#############
# .obj => .exe
#############
$(FULLBIN_ROOT)/%$(BINSUFFIX):
	@if [ ! -d $(@D) ] ; then \
		echo ">>> Creating $(@D)" ; \
		mkdir -p $(@D) ; \
	fi	
	@echo 
	@echo ">> $(notdir $+) --> $(subst $(FULLBIN_ROOT)/,,$@)"
	$(LD) $+ $(LDFLAGS) $(LIBS) /out:$@

