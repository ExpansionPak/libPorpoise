
SOURCE_ROOT=./src
PCEMU_ROOT=../../..

#################
# To Debug or Not
#################
ifdef DEBUG

BINSUFFIX=D.exe
LIBSUFFIX=D.lib
FULLBIN_ROOT=bin/win32/Debug
OBJ_ROOT=obj/win32/Debug
CCFLAGS=/nologo /MLd /W3 /Gm /GX /ZI /Od /D "WIN32" /D "EMU" /D "_DEBUG" /D "_WINDOWS" /YX /FD /c 
LDFLAGS=/libpath:../../../win32/lib /nologo /subsystem:windows /machine:I386 /debug

else

BINSUFFIX=.exe
LIBSUFFIX=.lib
FULLBIN_ROOT=bin/win32/Release
OBJ_ROOT=obj/win32/Release
CCFLAGS=/nologo /ML /W3 /GX /O2 /D "WIN32" /D "EMU" /D "NDEBUG" /D "_WINDOWS" /D "_MBCS" /c
LDFLAGS=/libpath:../../../win32/lib /nologo /subsystem:windows /machine:I386

endif

################
# Compiling
################
CC=cl.exe
INCLUDES=/I "include" /I "$(PCEMU_ROOT)\include"

################
# Linking
################
WIN32_LIBS = kernel32.lib user32.lib gdi32.lib winspool.lib \
	comdlg32.lib advapi32.lib shell32.lib ole32.lib oleaut32.lib \
	uuid.lib odbc32.lib odbccp32.lib \
	opengl32.lib glu32.lib dinput.lib dxguid.lib winmm.lib
DOLPHIN_LIB_NAMES = pcemu gx emu mtx pad demo charpipeline shader g2d
DOLPHIN_LIBS = $(addsuffix $(LIBSUFFIX), $(DOLPHIN_LIB_NAMES))
LIBS = $(WIN32_LIBS) $(DOLPHIN_LIBS)

LD=link.exe
	
.SUFFIXES:
.SUFFIXES: .s .h .c .o .cpp

