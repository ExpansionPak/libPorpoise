### --------------------------------------------------------------------------
#
# PROCEDURE
#   parseargs
#
# DESCRIPTION
#   Given a list of acceptable arguments, parses these out of 
#   the given list (with args, if requested), and
#   returns any unparseable arguments.
#
# ARGUMENTS
#   allowed_switches      Name of array of numbers, indexed by allowed 
#                         switches, stating the defaults for
#                         the returned_value array (the next argument)
#       0  -  set to zero     -  no argument (1 if switch present)
#       1  -  set to empty string                -  takes argument
#       2  -  default preset by calling routine  -  takes argument
#   returned_value        Name of array to fill in with parsed switch values
#   actual_list           List of switches,etc. to parse
#
# RETURN VALUE
#   unparsed_args         Anything not recognised/not a switch value
#
# ERRORS
#   missing_switch_value  If a switch taking an argument appears as 
#                         the last item without a value
#

proc parseargs {allowed_switches returned_values actual_list} {
    upvar $allowed_switches names
    upvar $returned_values results

    set count [llength $actual_list]
    set rejected {}
    set namelist [array names names]

    foreach i $namelist {
        switch -exact $names($i) {
            0 {set results($i)  0 }
            1 {set results($i) {} }
        }
    }

    for {set i 0} {$i < $count} {incr i} {
        set item [lindex $actual_list $i]
        if {[lsearch -exact $namelist $item]+1} {
            if {$names($item)} {
                incr i
                if {$i<$count} {
                    set results($item) [lindex $actual_list $i]
                } else {
                    error "Argument $item requires a value"
                }
            } else {
                set results($item) 1
            }
        } else {
            lappend rejected $item
        }
    }

    return $rejected
}

#
#  Parse args and print usage
#
set unArgs [parseargs keyArgs retArgs $argv]
if { $unArgs != "" } {
    puts "makesf - make single frame tests"
    puts " Arguments:"
    puts "   -search <pat>       -make test names that match the pattern"
    puts "                        can use *, ? wild cards, default is *"
    puts "   -frame <frame_num>  -make specific frame of the test, default"
    puts "                        is to make all frames"
    puts "   -debug              -make debug version of the tests"
    puts "   -mac                -build for MAC, default is SPRUCE_MARLIN"
    puts "   -even               -force even field"
    puts "   -odd                -force odd field"
    puts "   -dryrun             -don't make, just print commands"
    puts "   -help               -print usage message"
    puts ""
    exit
}

#
#  Set flags
#
if { !$retArgs(-debug) } {
    set ndebug "NDEBUG=TRUE"
    if { $retArgs(-mac) } {
        set suffix ".bin"
        set xsuffix ".xSYM"
        set sys "MAC"
    } else {
        set suffix ".elf"
        set sys "SPRUCE_MARLIN"
    }
    set objbase "obj/$sys/NDEBUG"
} else {
    set ndebug ""
    if { $retArgs(-mac) } {
        set suffix "D.bin"
        set xsuffix "D.xSYM"
        set sys "MAC"
    } else {
        set suffix "D.elf"
        set sys "SPRUCE_MARLIN"
    }
    set objbase "obj/$sys/DEBUG"
}

if { $retArgs(-even) } {
    set field "__EVENFIELD=TRUE"
	set fld "e"
} elseif { $retArgs(-odd) } {
    set field "__ODDFIELD=TRUE"
	set fld "o"
} else {
    set field ""
	set fld ""
}

set syscmd "PLATFORM=$sys"

#
#  Build tests
#
foreach t [array names tests] {
    # skip tests that don't match search criteria
    if [string match $retArgs(-search) $t] {
        set fname [format "%s%s" $t $suffix]
        regexp {([A-Za-z0-9]+)\-} $t dummy tpfx
        set objs [format "%s/%s/%s\*" $objbase $dirs($tpfx) $t]
        # compile single frame or all frames?
        if { $retArgs(-frame) < 0 } {
            # loop over frame numbers
            foreach f $tests($t) {
                puts "rm -f $objs"
                puts "make $ndebug $syscmd $field __SINGLEFRAME=$f $fname"
                if { !$retArgs(-dryrun) } {
                    # remove object files since each frame has the same name
                    exec rm -f $objs
                    exec $MAKE $ndebug $syscmd $field __SINGLEFRAME=$f $fname
                    cd "bin/$sys"
                    # move executable files to a new name with
                    # appended frame number
                    if { [file exists $fname] } {
                        set ffname [format "%s_%08x%s%s" $t $f $fld $suffix]
                        puts "mv $fname $ffname"
                        exec mv $fname $ffname
                        # move symbol file for cross-compiled Mac binary
                        if { $retArgs(-mac) && $retArgs(-debug) } {
                            set xname [format "%s%s" $t $xsuffix]
                            set ffname [format "%s_%08x%s%s" $t $f $fld $xsuffix]
                            puts "mv $xname $ffname"
                            exec mv $xname $ffname
                        }
                    }
                    cd "../.."
                }
            }
        } else {
            # run a single user-defined frame of this test
            puts "rm -f $objs"
            puts "make $ndebug $syscmd $field __SINGLEFRAME=$retArgs(-frame) $fname"
            if { !$retArgs(-dryrun) } {
                exec rm -f $objs
                exec $MAKE $ndebug $syscmd $field __SINGLEFRAME=$retArgs(-frame) $fname
                cd "bin/$sys"
                if { [file exists $fname] } {
                    set ffname [format "%s_%08x%s%s" $t $retArgs(-frame) $fld $suffix]
                    puts "mv $fname $ffname"
                    exec mv $fname $ffname
                    if { $retArgs(-mac) && $retArgs(-debug) } {
                        set xname [format "%s%s" $t $xsuffix]
                        set ffname [format "%s_%08x%s%s" $t $retArgs(-frame) $fld $xsuffix]
                        puts "mv $xname $ffname"
                        exec mv $xname $ffname
                    }
                }
                cd "../.."
            }
        }
    }
}

